{
  "name": "workproba-front",
  "version": "0.1.3",
  "description": "A Quasar Project",
  "productName": "Quasar App",
  "author": "Sylvain Meylan <sylvain@ateliom.fr>",
  "private": true,
  "scripts": {
    "generator": "ts-node -T generator/run.ts",
    "lint": "eslint .",
    "lint:i18n": "eslint src/",
    "format": "prettier --write \"**/*.{js,ts,vue,scss,html,md,json}\" --ignore-path .gitignore",
    "test:unit": "vitest run test/unit --coverage",
    "test:e2e": "yarn run playwright:install && playwright test e2e",
    "test:e2e:sidecar": "yarn run playwright:install && playwright test --config=playwright.sidecar.config.ts",
    "playwright:install": "playwright install chromium",
    "dev": "quasar dev",
    "dev:desktop": "quasar dev",
    "dev:ssr": "quasar dev -m ssr",
    "build": "quasar build",
    "build:ssr": "quasar build -m ssr",
    "docker:dev": "sh docker/compose.sh console",
    "type-check:file": "vue-tsc --noEmit -p tsconfig.vue-tsc.json"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/varela-round": "^5.2.8",
    "@quasar/extras": "^1.18.0",
    "@types/file-saver": "^2.0.7",
    "@vueuse/core": "^13.2.0",
    "anubis-ui": "^1.4.4",
    "axios": "^1.16.1",
    "compression": "^1.7.5",
    "dompurify": "^3.4.11",
    "dotenv": "^16.6.0",
    "exceljs": "^4.4.0",
    "express": "^4.21.0",
    "file-saver": "^2.0.5",
    "katex": "^0.16.22",
    "lucide-vue-next": "^0.563.0",
    "markdown-it": "^14.1.0",
    "quasar": "^2.19.3",
    "shiki": "^3.4.0",
    "tsc-alias": "^1.8.17",
    "vue": "^3.5.34",
    "vue-i18n": "^11.4.4",
    "vue-router": "^5.0.7",
    "vue-virtual-scroller": "^2.0.0-beta.8",
    "vue3-keypress": "^4.0.1"
  },
  "resolutions": {
    "minimatch": "^9.0.7",
    "picomatch": "^4.0.4",
    "serialize-javascript": "^7.0.5",
    "flatted": "^3.4.2",
    "path-to-regexp": "^0.1.13",
    "yaml": "^2.8.3",
    "lodash": "^4.18.0",
    "follow-redirects": "^1.16.0",
    "postcss": "^8.5.10",
    "immutable": "^5.1.5",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@intlify/eslint-plugin-vue-i18n": "^4.5.1",
    "@intlify/unplugin-vue-i18n": "^11.2.3",
    "@playwright/test": "^1.60.0",
    "@quasar/app-vite": "^2.6.0",
    "@tauri-apps/api": "^2.4.0",
    "@types/compression": "^1.8.1",
    "@types/dompurify": "^3.2.0",
    "@types/express": "^4.17.21",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "4.1.7",
    "@vue/test-utils": "^2.4.10",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "happy-dom": "^20.9.0",
    "prettier": "^3.8.3",
    "sass": "^1.100.0",
    "typescript": "^6.0.0",
    "vite-plugin-checker": "^0.13.0",
    "vitest": "^4.1.7",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.3.1"
  },
  "engines": {
    "node": "^24 || ^22 || ^20",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1"
  }
}
