{
  "files": {
    "targets": ["**/*.vue", "**/*use-mastok.ts"],
    "ignore": []
  },
  "utilities": [
    {
      "prefix": "bg",
      "declaration": "background: ${color}",
      "export": "all"
    },
    {
      "prefix": "text",
      "declaration": "color: ${color}",
      "export": "all"
    },
    {
      "prefix": "border",
      "declaration": "border-width: ${value} !important; border-color: ${color} !important; border-style: solid;",
      "variations": {
        "default": "1px",
        "xs": "1px",
        "sm": "2px",
        "md": "3px",
        "lg": "6px",
        "xl": "8px",
        "xxl": "10px",
        "node": "0.2rem"
      }
    },
    {
      "prefix": "inner-border",
      "declaration": "box-shadow: inset 0px 0px 0px ${value} ${color}",
      "variations": {
        "default": "1px",
        "xs": "1px",
        "sm": "2px",
        "md": "3px",
        "lg": "6px",
        "xl": "8px",
        "xxl": "10px",
        "node": "0.2rem"
      }
    },
    {
      "prefix": "shadow",
      "declaration": "box-shadow: ${value} ${color}",
      "variations": {
        "default": "0px 0px 7px 1px",
        "xs": "0px 0px 3px 1px",
        "sm": "0px 0px 5px 1px",
        "md": "0px 0px 5px 1px",
        "lg": "0px 0px 10px 1px",
        "xl": "0px 0px 15px 1px"
      }
    },
    {
      "prefix": "blur",
      "declaration": "backdrop-filter: blur(${value})",
      "variations": {
        "default": "3px"
      }
    },
    {
      "prefix": "smooth",
      "declaration": "transition-duration: ${value}",
      "variations": {
        "default": "0.1s",
        "slowest": "0.5s",
        "slower": "0.3s",
        "slow": "0.2s",
        "quick": "0.07s",
        "quicker": "0.05s",
        "quickest": "0.03s"
      }
    },
    {
      "prefix": "rounded",
      "declaration": "border-radius: ${value}",
      "variations": {
        "default": "4px",
        "square": "0px",
        "xs": "2px",
        "sm": "4px",
        "md": "8px",
        "lg": "12px",
        "xl": "16px",
        "very": "9999px",
        "full": "50%",
        "half": "100%"
      }
    },
    {
      "prefix": "border",
      "declaration": "border-style: ${value}",
      "variations": {
        "solid": "solid",
        "dashed": "dashed",
        "dotted": "dotted"
      }
    },
    {
      "prefix": "text",
      "declaration": "text-decoration: ${value}",
      "variations": {
        "underline": "underline",
        "dashed": "dashed",
        "dotted": "dotted"
      }
    },
    {
      "prefix": "position",
      "declaration": "position: ${value}",
      "variations": {
        "relative": "relative",
        "absolute": "absolute"
      }
    },
    {
      "prefix": "size",
      "declaration": "font-size: ${value} !important",
      "export": "variations",
      "variations": {
        "2xs": "10px",
        "xs": "12px",
        "sm": "14px",
        "md": "16px",
        "lg": "18px",
        "xl": "20px",
        "2xl": "24px",
        "3xl": "30px",
        "4xl": "36px",
        "5xl": "48px",
        "6xl": "60px",
        "7xl": "72px",
        "8xl": "96px",
        "9xl": "128px"
      }
    },
    {
      "prefix": "weight",
      "declaration": "font-weight: ${value} !important",
      "export": "variations",
      "variations": {
        "thin": "100",
        "extra-light": "200",
        "light": "300",
        "normal": "400",
        "medium": "500",
        "semi-bold": "600",
        "bold": "700",
        "extra-bold": "800",
        "black": "900"
      }
    }
  ],
