{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "skipLibCheck": true,
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "es2022",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    // strict mode
    "strict": true,
    // says if a code will never execute
    "allowUnreachableCode": false,
    // https://www.typescriptlang.org/tsconfig#allowUnusedLabels
    "allowUnusedLabels": false,
    // https://www.typescriptlang.org/tsconfig#noImplicitReturns
    "noImplicitReturns": true,
    // https://www.typescriptlang.org/tsconfig#noPropertyAccessFromIndexSignature
    // "noPropertyAccessFromIndexSignature": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitOverride": true,
    "resolveJsonModule": true,
    "noErrorTruncation": true,
    "paths": {
      "@lib-improba/*": [
        "lib-improba/*"
      ],
      "@core/*": [
        "src/core/*"
      ],
      "@users/*": [
        "src/core/users/*"
      ],
      "@utils/*": [
        "lib-improba/*"
      ],
      "@auth-jwt/*": [
        "lib-improba/modules/auth-jwt/*"
      ],
      "@test/*": [
        "test/*"
      ]
    },
    "types": ["node", "vitest/globals"]
  },
  "ts-node": {
    "require": [
      "tsconfig-paths/register"
    ]
  },
  "exclude": [
    "node_modules",
    "dist",
    "migrations",
    "lib-improba/modules/cms",
    "vitest.config.ts"
  ]
}