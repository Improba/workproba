# ============================================
# Database Configuration
# ============================================
DB_TYPE=postgres
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password
DB_NAME=your_db_name
DB_HOST=workproba-api-dev-db
DB_PORT=5432
DB_SSLCERT=

# ============================================
# JWT Authentication (auth-jwt module)
# ============================================
# Clé secrète pour signer les tokens JWT (obligatoire)
JWT_SECRET=your_jwt_secret_key_here_make_it_long_and_random
# Durée de validité des tokens JWT (optionnel, défaut: 1h)
# Format: '1h', '30m', '3600s', etc.
JWT_EXPIRES_IN=1h
# URL du frontend pour les redirections (obligatoire)
API_URL=http://localhost:5051
FRONTEND_URL=http://localhost:5053
# Nom de l'application utilisé dans les emails (optionnel, défaut: Application)
APP_NAME=workproba-api

# ============================================
# Mailing Configuration (mailing module)
# ============================================
# Provider de mailing: 'brevo' (défaut) ou 'sendgrid'
MAILING_PROVIDER=brevo

# This will create the first admin user upon first start
ADMINUSER_LOGIN=admin@improba.fr
ADMINUSER_PASSWORD=s0me-l0ong+Str0ng-p@ssw0rd

# Clé API Brevo (requis si MAILING_PROVIDER=brevo)
BREVO_API_KEY=xkeysib-your_brevo_api_key_here

# Clé API SendGrid (requis si MAILING_PROVIDER=sendgrid)
# Note: SENDGRID_API_KEY et EMAIL_FROM sont également utilisées par le module auth-jwt
# pour l'envoi d'emails de réinitialisation de mot de passe (code legacy)
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here

# Adresse email expéditrice (requis pour l'envoi d'emails)
# Ne bloque pas le démarrage si non définie, mais les emails échoueront
EMAIL_FROM=test@improba.eu
# Nom de l'expéditeur (optionnel)
EMAIL_FROM_NAME=My Application
# Chemin vers les templates Handlebars (optionnel, défaut: templates/emails)
TEMPLATES_PATH=templates/emails

# ============================================
# Docker Configuration
# ============================================
BACKEND_DOCKER_APP_PORT_EXPOSED=5051
BACKEND_DOCKER_PSQL_PORT_EXPOSED=5052

# ============================================
# Internal AI Service
# ============================================
AI_SERVICE_URL=http://workproba-ai:8000
AI_INTERNAL_SECRET=change-me-internal-secret

# ============================================
# LLM Providers
# ============================================
LLM_PROVIDER_KIND=openai-compatible
LLM_PROVIDER_BASE_URL=http://localhost:11434/v1
LLM_PROVIDER_API_KEY=change-me
LLM_PROVIDER_DEFAULT_MODEL=llama3.1
LLM_PROVIDER_EMBEDDING_MODEL=text-embedding-3-small
