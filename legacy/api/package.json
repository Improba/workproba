  "scripts": {
    "generator": "ts-node -T generator/run.ts",
    "prebuild": "rimraf dist",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"lib-improba/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch ",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main",
    "lint:fix": "eslint \"{src,lib-improba}/**/*.ts\" --fix && yarn format",
    "test:unit": "vitest run test/unit --coverage",
		"test:e2e": "vitest run test/e2e --coverage",
    "mikro-orm": "MIKRO_ORM_CLI_CONFIG=./config/migrations.config.ts mikro-orm ",
    "migration:create": "yarn mikro-orm migration:create --name",
    "migration:generate": "yarn migration:create",
    "migration:up": "yarn mikro-orm migration:up",
    "migration:run": "yarn migration:up",
    "migration:down": "yarn mikro-orm migration:down",
    "migration:list": "yarn mikro-orm migration:list",
    "migration:fresh": "yarn mikro-orm migration:fresh",
    "migration:check": "yarn mikro-orm migration:check",
    "migration:pending": "yarn mikro-orm migration:pending",
    "console": "ts-node --project ./tsconfig.json ./src/core/scripts/console.ts",
    "docker:dev": "sh docker/compose.sh console"
  },
