HOST=127.0.0.1
PORT=8765
PROJECT_ROOT=
CORS_ORIGINS=http://127.0.0.1:5053,http://localhost:5053,http://127.0.0.1:8765,http://localhost:8765,tauri://localhost,http://tauri.localhost
# Regex complémentaire d'origines autorisées (loopback IPv4/IPv6/tauri, port libre).
# Laisser vide pour désactiver et garder uniquement CORS_ORIGINS explicite.
CORS_ORIGIN_REGEX=^(https?://(localhost|127\.0\.0\.1|\[::1\]|tauri\.localhost)(:\d+)?|tauri://localhost)$

INTERNAL_SECRET=desktop-dev-secret

# Chat/agent (Pydantic AI natif). Config gérée depuis l'app (écran « Modèles IA ») ;
# ces variables ne sont qu'un REPLI de dev quand l'app n'envoie pas de config par tour.
#   Mistral (OpenAI-compat) : provider=mistral, base_url=https://api.mistral.ai/v1, model=mistral-small-latest
#   Ollama local            : provider=openai_compat, base_url=http://127.0.0.1:11434/v1, model=mistral/llama3
#   vLLM / LM Studio        : provider=openai_compat, base_url=http://<host>/v1
LLM_DEFAULT_PROVIDER=mistral
LLM_DEFAULT_BASE_URL=https://api.mistral.ai/v1
LLM_DEFAULT_API_KEY=
LLM_DEFAULT_MODEL=mistral-small-latest

# RAG local (sqlite-vec). Embeddings via LiteLLM. Laisser vide pour désactiver
# (replie sur recherche substring). Clé également gérée depuis l'app.
# Ex. Mistral : LLM_EMBEDDING_PROVIDER=mistral + LLM_EMBEDDING_MODEL=mistral-embed
# Ex. Ollama   : LLM_EMBEDDING_PROVIDER=ollama + LLM_EMBEDDING_MODEL=nomic-embed-text
LLM_EMBEDDING_PROVIDER=mistral
LLM_EMBEDDING_MODEL=mistral-embed
LLM_EMBEDDING_BASE_URL=https://api.mistral.ai/v1
LLM_EMBEDDING_API_KEY=

SANDBOX_TIMEOUT_SECONDS=60
MAX_AGENT_ITERATIONS=6
LOG_LEVEL=INFO
