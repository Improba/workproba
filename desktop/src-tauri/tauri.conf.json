{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Workproba",
  "version": "0.1.0",
  "identifier": "fr.improba.workproba",
  "build": {
    "frontendDist": "../../front/dist/spa",
    "devUrl": "http://localhost:5053",
    "beforeDevCommand": "cd ../front && DESKTOP_MODE=true yarn dev",
    "beforeBuildCommand": "cd ../front && DESKTOP_MODE=true yarn build"
  },
  "app": {
    "windows": [
      {
        "title": "Workproba",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**/*"]
      }
    }
  },
  "bundle": {
    "active": true,
    "externalBin": ["binaries/workproba-ai"],
    "targets": ["deb", "appimage", "msi", "nsis", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Improba",
    "copyright": "Copyright © Improba",
    "category": "Productivity",
    "shortDescription": "Assistant de travail local-first",
    "longDescription": "Workproba est un assistant de travail bilingue pour documents locaux et collaboration projet.",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "wix": {
        "language": ["fr-FR", "en-US"]
      },
      "nsis": {
        "installMode": "both"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.13",
      "signingIdentity": null,
      "entitlements": null
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libayatana-appindicator3-1"],
        "section": "utils"
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
